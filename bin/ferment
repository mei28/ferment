#!/usr/bin/env bash
# ferment — a thin Mutagen wrapper that ferments your file changes.
#
# https://github.com/mei28/ferment
#
# Goals:
#   - Short subcommands instead of "mutagen sync ..." / "mutagen project ..."
#   - One pretty status line per session (connected? syncing? conflicts?)
#   - Works on top of `mutagen project` (ferment.yml or mutagen.yml).
#
# Naming: mutagen = "agent that causes mutation". ferment = "agent that
# causes (slow, biological) change". A wrapper that quietly ferments
# your file changes into propagation across hosts.
#
# License: MIT

set -euo pipefail

VERSION="0.1.0"
SELF="$(basename "${0}")"
VERBOSE=0

# Preserve a handle to the *original* stderr so `-v` output isn't swallowed
# by per-call `2>/dev/null` redirections inside the script (e.g. in $(...)).
exec 9>&2

# ---------- ui ----------

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  C_RESET=$'\033[0m'
  C_BOLD=$'\033[1m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_BLUE=$'\033[34m'
  C_CYAN=$'\033[36m'
else
  C_RESET=""; C_BOLD=""; C_DIM=""
  C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_CYAN=""
fi

err()  { printf "%serror:%s %s\n" "$C_RED" "$C_RESET" "$*" >&2; exit 1; }
info() { printf "%s->%s %s\n"     "$C_BLUE" "$C_RESET" "$*"; }
ok()   { printf "%s✓%s %s\n"      "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf "%s!%s %s\n"      "$C_YELLOW" "$C_RESET" "$*"; }

need() { command -v "$1" >/dev/null 2>&1 || err "$1 not found on PATH"; }
# Note: `need mutagen` is enforced per-subcommand in dispatch so that
# offline-friendly commands (`help`, `version`, `init`, `completion`) work
# before mutagen is installed.

# Wrap external command invocations. With -v, prints the command line to the
# original stderr (FD 9) before exec; otherwise behaves like a transparent
# pass-through. Using FD 9 keeps the trace visible even when callers redirect
# stderr (e.g. `out=$(run mutagen ... 2>/dev/null)`).
run() {
  if [ "$VERBOSE" = "1" ]; then
    printf "%s\$%s %s\n" "$C_DIM" "$C_RESET" "$*" >&9
  fi
  "$@"
}

# Locate the project file. ferment.yml is preferred; mutagen.yml accepted
# for compatibility. When found, the path is stored in $project_file and
# (for non-default names) passed to `mutagen project` via --project-file.
project_file=""
locate_project() {
  if   [ -f ferment.yml  ]; then project_file="ferment.yml"
  elif [ -f ferment.yaml ]; then project_file="ferment.yaml"
  elif [ -f mutagen.yml  ]; then project_file="mutagen.yml"
  elif [ -f mutagen.yaml ]; then project_file="mutagen.yaml"
  else                           project_file=""
  fi
}

# ---------- help ----------

cmd_help() {
  cat <<EOF
${C_BOLD}${SELF}${C_RESET} v${VERSION} — a thin Mutagen wrapper for daily use
${C_DIM}https://github.com/mei28/ferment${C_RESET}

${C_BOLD}Usage:${C_RESET} ${SELF} [-v] <subcommand> [args]

${C_BOLD}Project${C_RESET} (operates on cwd's ferment.yml / mutagen.yml)
  ${C_CYAN}init${C_RESET} [name]      generate a ferment.yml template
  ${C_CYAN}up${C_RESET}               start the project   (mutagen project start)
  ${C_CYAN}down${C_RESET}             terminate the project (mutagen project terminate)
  ${C_CYAN}reload${C_RESET}           down then up

${C_BOLD}Status${C_RESET}
  ${C_CYAN}st${C_RESET}               colored one-line status summary
  ${C_CYAN}watch${C_RESET}            re-render st every 2 seconds
  ${C_CYAN}mon${C_RESET}              raw mutagen sync monitor stream
  ${C_CYAN}why${C_RESET} [session]    detail view (conflicts / problems / scan stats)

${C_BOLD}Sync ops${C_RESET}
  ${C_CYAN}flush${C_RESET} [session]  flush now (defaults to --all)
  ${C_CYAN}pause${C_RESET} [session]  pause     (defaults to --all)
  ${C_CYAN}resume${C_RESET} [session] resume    (defaults to --all)
  ${C_CYAN}reset${C_RESET} [session]  reset     (defaults to --all)
  ${C_CYAN}pick${C_RESET}             fzf-pick a session name (to stdout)

${C_BOLD}Config${C_RESET}
  ${C_CYAN}edit${C_RESET}             open the project file in \$EDITOR
  ${C_CYAN}path${C_RESET}             print absolute path of the project file
  ${C_CYAN}daemon${C_RESET}           show mutagen daemon status
  ${C_CYAN}completion${C_RESET} <sh>  print shell completion script (bash|zsh|fish)

${C_BOLD}Global flags${C_RESET}
  ${C_CYAN}-v${C_RESET}, ${C_CYAN}--verbose${C_RESET}    echo each mutagen invocation before running it

${C_DIM}Suggested alias: alias f=${SELF}${C_RESET}
EOF
}

# ---------- commands ----------

cmd_init() {
  local name="${1:-$(basename "$PWD")}"
  if [ -f ferment.yml ] || [ -f ferment.yaml ] || [ -f mutagen.yml ] || [ -f mutagen.yaml ]; then
    err "a project file already exists (ferment.yml / mutagen.yml)"
  fi
  cat > ferment.yml <<EOF
# ferment project: ${name}
# docs: https://github.com/mei28/ferment
# upstream: https://mutagen.io/documentation/orchestration/projects
#
# Quick start:
#   ferment up      # start
#   ferment st      # status
#   ferment down    # stop
#
# Edit alpha/beta below to match your environment.

sync:
  defaults:
    mode: two-way-resolved
    ignore:
      vcs: true
      paths:
        - .DS_Store
        - .git
        - node_modules
        - .venv
        - __pycache__
        - .pytest_cache
        - .mypy_cache
        - .idea
        - .vscode
        - "*.swp"
        - "*.tmp"
    permissions:
      defaultFileMode: 0644
      defaultDirectoryMode: 0755
    symlink:
      mode: portable
    watch:
      mode: portable
      pollingInterval: 10
    flushOnCreate: true

  ${name}-code:
    alpha: "."
    beta: "user@host:/srv/${name}"

# beforeCreate:   ["echo [ferment] starting ${name}"]
# afterTerminate: ["echo [ferment] stopped ${name}"]
EOF
  ok "created ferment.yml (project: ${name})"
  info "edit alpha/beta: ${C_CYAN}${SELF} edit${C_RESET}"
  info "start it:        ${C_CYAN}${SELF} up${C_RESET}"
}

cmd_up() {
  locate_project
  if [ -z "$project_file" ]; then
    warn "no project file in cwd. Create one with: ${SELF} init"
    exit 1
  fi
  # `mutagen project` auto-discovers mutagen.yml; for ferment.yml we must
  # pass --project-file explicitly.
  case "$project_file" in
    mutagen.yml|mutagen.yaml) run mutagen project start ;;
    *)                        run mutagen project start --project-file "$project_file" ;;
  esac
  ok "project started"
  cmd_st || true
}

cmd_down() {
  locate_project
  case "$project_file" in
    ""|mutagen.yml|mutagen.yaml) run mutagen project terminate || true ;;
    *)                           run mutagen project terminate --project-file "$project_file" || true ;;
  esac
  ok "project terminated"
}

cmd_reload() {
  cmd_down
  cmd_up
}

# Pretty one-line status. Uses --template so column widths don't matter.
cmd_st() {
  local tmpl
  tmpl='{{range .}}{{.Name}}|{{.Alpha.URL}}|{{.Beta.URL}}|{{if .Alpha.Connected}}Y{{else}}N{{end}}|{{if .Beta.Connected}}Y{{else}}N{{end}}|{{.Status}}|{{len .Conflicts}}|{{len .AlphaState.Problems}}|{{len .BetaState.Problems}}
{{end}}'

  local out
  if ! out=$(run mutagen sync list --template "$tmpl" 2>/dev/null); then
    warn "this mutagen version doesn't support --template; falling back to raw output"
    run mutagen sync list
    return
  fi

  if [ -z "$out" ]; then
    warn "no sync sessions  (start with '${SELF} up' or 'mutagen sync create ...')"
    return
  fi

  printf "%s%-24s %-3s %-3s %-26s %-4s %-4s %s%s\n" \
    "$C_BOLD" "NAME" "A" "B" "STATUS" "CFL" "PRB" "ALPHA <-> BETA" "$C_RESET"

  while IFS='|' read -r name aurl burl ac bc status conflicts ap bp; do
    [ -z "$name" ] && continue

    local ac_s bc_s cfl_s prb_s status_c
    if [ "$ac" = "Y" ]; then ac_s="${C_GREEN}✓${C_RESET}"; else ac_s="${C_RED}✗${C_RESET}"; fi
    if [ "$bc" = "Y" ]; then bc_s="${C_GREEN}✓${C_RESET}"; else bc_s="${C_RED}✗${C_RESET}"; fi

    if [ "${conflicts:-0}" -gt 0 ] 2>/dev/null; then
      cfl_s="${C_RED}${conflicts}${C_RESET}"
    else
      cfl_s="${C_DIM}0${C_RESET}"
    fi

    local prb=$(( ${ap:-0} + ${bp:-0} ))
    if [ "$prb" -gt 0 ]; then
      prb_s="${C_RED}${prb}${C_RESET}"
    else
      prb_s="${C_DIM}0${C_RESET}"
    fi

    case "$status" in
      *atching*)                                     status_c="${C_GREEN}${status}${C_RESET}" ;;
      *canning*|*taging*|*econciling*|*pplying*|*ransitioning*|*aving*)
                                                     status_c="${C_YELLOW}${status}${C_RESET}" ;;
      *aused*|*alted*|*isconnected*|*error*|*Error*) status_c="${C_RED}${status}${C_RESET}" ;;
      *)                                             status_c="$status" ;;
    esac

    printf "%-24s %b   %b   %b %b %b %s %s<->%s %s\n" \
      "$name" "$ac_s" "$bc_s" "$status_c" "$cfl_s" "$prb_s" \
      "$aurl" "$C_DIM" "$C_RESET" "$burl"
  done <<< "$out"
}

cmd_watch() {
  trap 'tput cnorm 2>/dev/null || true; exit 0' INT TERM
  tput civis 2>/dev/null || true
  while true; do
    clear
    printf "%s%s%s   %sCtrl-C to exit%s\n\n" "$C_DIM" "$(date '+%Y-%m-%d %H:%M:%S')" "$C_RESET" "$C_DIM" "$C_RESET"
    cmd_st || true
    sleep 2
  done
}

cmd_mon()    { run mutagen sync monitor "$@"; }
cmd_why()    { run mutagen sync list --long "$@"; }
cmd_edit()   {
  locate_project
  if [ -z "$project_file" ]; then err "no project file found (create one with: ${SELF} init)"; fi
  ${EDITOR:-vi} "$project_file"
}
cmd_path()   {
  locate_project
  if [ -z "$project_file" ]; then warn "no project file found"; exit 1; fi
  if command -v realpath >/dev/null 2>&1; then
    realpath "$project_file"
  else
    printf "%s/%s\n" "$PWD" "$project_file"
  fi
}
cmd_daemon() { run mutagen daemon status 2>/dev/null || run mutagen daemon status || true; }

generic_op() {
  local op="$1"; shift
  if [ "$#" -eq 0 ]; then
    run mutagen sync "$op" --all
    ok "${op} all sessions"
  else
    run mutagen sync "$op" "$@"
    ok "${op} $*"
  fi
}

cmd_flush()  { generic_op flush  "$@"; }
cmd_pause()  { generic_op pause  "$@"; }
cmd_resume() { generic_op resume "$@"; }
cmd_reset()  { generic_op reset  "$@"; }

cmd_pick() {
  need fzf
  run mutagen sync list --template '{{range .}}{{.Name}}
{{end}}' | fzf --prompt="session > "
}

# ---------- completion ----------
#
# Source of truth for shell completion. The static files under completions/
# are generated from this (see `just regen-completions`). The body of each
# branch is a heredoc with single-quoted delimiter so `$`, backticks etc.
# are emitted literally.

cmd_completion() {
  local shell="${1:-}"
  case "$shell" in
    bash) cat <<'__FERMENT_BASH_COMPLETION__'
# bash completion for ferment
# Install:
#   ferment completion bash > ~/.local/share/bash-completion/completions/ferment
# or
#   source <(ferment completion bash)

_ferment() {
  local cur prev words cword
  if declare -F _init_completion >/dev/null 2>&1; then
    _init_completion || return
  else
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    words=("${COMP_WORDS[@]}")
    cword=$COMP_CWORD
  fi

  local subcmds="help version init up down reload st watch mon why \
flush pause resume reset pick edit path daemon completion"
  local global_flags="-v --verbose -h --help -V --version"

  # Walk all words before the cursor and pick the first non-flag token as
  # the subcommand. This makes `-v` etc. positionally independent.
  local sub="" i
  for (( i=1; i<cword; i++ )); do
    case "${words[i]}" in
      -v|--verbose|-h|--help|-V|--version) continue ;;
      -*) continue ;;
      *) sub="${words[i]}"; break ;;
    esac
  done

  if [ -z "$sub" ]; then
    case "$cur" in
      -*) COMPREPLY=( $(compgen -W "$global_flags" -- "$cur") ) ;;
      *)  COMPREPLY=( $(compgen -W "$subcmds" -- "$cur") ) ;;
    esac
    return 0
  fi

  case "$sub" in
    flush|f|sync|pause|resume|reset|why|long|detail|mon|monitor)
      if command -v mutagen >/dev/null 2>&1; then
        local sessions
        sessions=$(mutagen sync list --template '{{range .}}{{.Name}}
{{end}}' 2>/dev/null)
        COMPREPLY=( $(compgen -W "$sessions" -- "$cur") )
      fi
      ;;
    completion)
      COMPREPLY=( $(compgen -W "bash zsh fish" -- "$cur") )
      ;;
  esac
}

complete -F _ferment ferment
__FERMENT_BASH_COMPLETION__
      ;;
    zsh) cat <<'__FERMENT_ZSH_COMPLETION__'
#compdef ferment
# zsh completion for ferment
# Install:
#   ferment completion zsh > "${fpath[1]}/_ferment"
# or
#   eval "$(ferment completion zsh)"

_ferment() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a subcmds=(
    'help:show help'
    'version:show version'
    'init:create ferment.yml template in cwd'
    'up:start project (mutagen project start)'
    'down:terminate project'
    'reload:down then up'
    'st:colored 1-line status summary'
    'watch:re-render st every 2 seconds'
    'mon:mutagen sync monitor (raw stream)'
    'why:per-session details (conflicts, problems)'
    'flush:flush sessions (default --all)'
    'pause:pause sessions (default --all)'
    'resume:resume sessions (default --all)'
    'reset:reset sessions (default --all)'
    'pick:fzf-pick a session name'
    'edit:open project file in $EDITOR'
    'path:print absolute path of project file'
    'daemon:show mutagen daemon status'
    'completion:print shell completion script'
  )

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[print mutagen commands as they run]' \
    '1: :->cmd' \
    '*:: :->args' && return 0

  case $state in
    cmd)
      _describe -t commands 'ferment subcommand' subcmds
      ;;
    args)
      case $line[1] in
        flush|f|sync|pause|resume|reset|why|long|detail|mon|monitor)
          _ferment_sessions
          ;;
        completion)
          _values 'shell' bash zsh fish
          ;;
      esac
      ;;
  esac
}

_ferment_sessions() {
  local -a sessions
  if command -v mutagen >/dev/null 2>&1; then
    sessions=(${(f)"$(mutagen sync list --template '{{range .}}{{.Name}}
{{end}}' 2>/dev/null)"})
    if (( ${#sessions} )); then
      _describe -t sessions 'sync session' sessions
    fi
  fi
}

_ferment "$@"
__FERMENT_ZSH_COMPLETION__
      ;;
    fish) cat <<'__FERMENT_FISH_COMPLETION__'
# fish completion for ferment
# Install:
#   ferment completion fish > ~/.config/fish/completions/ferment.fish

complete -c ferment -f

# Global flags (available before subcommand)
complete -c ferment -s v -l verbose -d "Print mutagen commands as they run"
complete -c ferment -s h -l help    -d "Show help"
complete -c ferment -s V -l version -d "Show version"

# Subcommand suggestions when none seen yet
complete -c ferment -n "__fish_use_subcommand" -a help       -d "show help"
complete -c ferment -n "__fish_use_subcommand" -a version    -d "show version"
complete -c ferment -n "__fish_use_subcommand" -a init       -d "create ferment.yml template"
complete -c ferment -n "__fish_use_subcommand" -a up         -d "start project"
complete -c ferment -n "__fish_use_subcommand" -a down       -d "terminate project"
complete -c ferment -n "__fish_use_subcommand" -a reload     -d "down then up"
complete -c ferment -n "__fish_use_subcommand" -a st         -d "1-line status summary"
complete -c ferment -n "__fish_use_subcommand" -a watch      -d "live st (2s refresh)"
complete -c ferment -n "__fish_use_subcommand" -a mon        -d "mutagen sync monitor"
complete -c ferment -n "__fish_use_subcommand" -a why        -d "per-session details"
complete -c ferment -n "__fish_use_subcommand" -a flush      -d "flush sessions"
complete -c ferment -n "__fish_use_subcommand" -a pause      -d "pause sessions"
complete -c ferment -n "__fish_use_subcommand" -a resume     -d "resume sessions"
complete -c ferment -n "__fish_use_subcommand" -a reset      -d "reset sessions"
complete -c ferment -n "__fish_use_subcommand" -a pick       -d "fzf-pick a session"
complete -c ferment -n "__fish_use_subcommand" -a edit       -d "open project file"
complete -c ferment -n "__fish_use_subcommand" -a path       -d "print project file path"
complete -c ferment -n "__fish_use_subcommand" -a daemon     -d "daemon status"
complete -c ferment -n "__fish_use_subcommand" -a completion -d "print completion script"

function __ferment_sessions
    if command -v mutagen >/dev/null
        mutagen sync list --template '{{range .}}{{.Name}}
{{end}}' 2>/dev/null
    end
end

complete -c ferment \
    -n "__fish_seen_subcommand_from flush f sync pause resume reset why long detail mon monitor" \
    -a "(__ferment_sessions)"

complete -c ferment -n "__fish_seen_subcommand_from completion" -a bash -d "Bash"
complete -c ferment -n "__fish_seen_subcommand_from completion" -a zsh  -d "Zsh"
complete -c ferment -n "__fish_seen_subcommand_from completion" -a fish -d "Fish"
__FERMENT_FISH_COMPLETION__
      ;;
    "")  err "missing shell name (bash|zsh|fish)" ;;
    *)   err "unsupported shell: $shell (use bash|zsh|fish)" ;;
  esac
}

# ---------- dispatch ----------

# Strip global flags (`-v`/`--verbose`) from arbitrary positions so they
# work both before and after the subcommand. Anything else is preserved.
_rest=()
for _arg in "$@"; do
  case "$_arg" in
    -v|--verbose) VERBOSE=1 ;;
    *) _rest+=("$_arg") ;;
  esac
done
set -- ${_rest[@]+"${_rest[@]}"}
unset _rest _arg

sub="${1:-help}"
shift || true

# Subcommands that must not require mutagen on PATH (so users can set up
# completions before installing mutagen).
case "$sub" in
  help|-h|--help|""|version|-V|--version|init|completion|path|edit|e) ;;
  *) need mutagen ;;
esac

case "$sub" in
  help|-h|--help|"")             cmd_help ;;
  version|-V|--version)          echo "${SELF} ${VERSION}" ;;
  init)                          cmd_init "$@" ;;
  up|start)                      cmd_up ;;
  down|stop|term|terminate)      cmd_down ;;
  reload|restart)                cmd_reload ;;
  st|status|ls|list)             cmd_st ;;
  watch|w)                       cmd_watch ;;
  mon|monitor)                   cmd_mon "$@" ;;
  why|long|detail)               cmd_why "$@" ;;
  flush|f|sync)                  cmd_flush "$@" ;;
  pause)                         cmd_pause "$@" ;;
  resume)                        cmd_resume "$@" ;;
  reset)                         cmd_reset "$@" ;;
  pick)                          cmd_pick ;;
  edit|e)                        cmd_edit ;;
  path)                          cmd_path ;;
  daemon)                        cmd_daemon ;;
  completion)                    cmd_completion "$@" ;;
  *) err "unknown subcommand: $sub  (try '${SELF} help')" ;;
esac
