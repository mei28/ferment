#compdef ferment
# zsh completion for ferment
# Install:
#   ferment completion zsh > "${fpath[1]}/_ferment"
# or
#   eval "$(ferment completion zsh)"

_ferment() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a subcmds=(
    'help:show help'
    'version:show version'
    'init:create ferment.yml template in cwd'
    'up:start project (mutagen project start)'
    'down:terminate project'
    'reload:down then up'
    'st:colored 1-line status summary'
    'watch:re-render st every 2 seconds'
    'mon:mutagen sync monitor (raw stream)'
    'why:per-session details (conflicts, problems)'
    'flush:flush sessions (default --all)'
    'pause:pause sessions (default --all)'
    'resume:resume sessions (default --all)'
    'reset:reset sessions (default --all)'
    'pick:fzf-pick a session name'
    'edit:open project file in $EDITOR'
    'path:print absolute path of project file'
    'daemon:show mutagen daemon status'
    'completion:print shell completion script'
  )

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[print mutagen commands as they run]' \
    '1: :->cmd' \
    '*:: :->args' && return 0

  case $state in
    cmd)
      _describe -t commands 'ferment subcommand' subcmds
      ;;
    args)
      case $line[1] in
        flush|f|sync|pause|resume|reset|why|long|detail|mon|monitor)
          _ferment_sessions
          ;;
        completion)
          _values 'shell' bash zsh fish
          ;;
      esac
      ;;
  esac
}

_ferment_sessions() {
  local -a sessions
  if command -v mutagen >/dev/null 2>&1; then
    sessions=(${(f)"$(mutagen sync list --template '{{range .}}{{.Name}}
{{end}}' 2>/dev/null)"})
    if (( ${#sessions} )); then
      _describe -t sessions 'sync session' sessions
    fi
  fi
}

_ferment "$@"
